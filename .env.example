# ==========================================
# ML AGENTS UNIVERSE — Environment Variables
# ==========================================
# Salin file ini ke .env dan isi dengan nilai yang sesuai.
# JANGAN PERNAH commit file .env ke repository!
# ==========================================

# --- Core Application ---
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=false

# --- LLM Provider Selection ---
# Provider: ollama, openai, anthropic, gemini, groq, mistral, together, openrouter, huggingface
LLM_PROVIDER=ollama
LLM_MODEL=uis_quan

# --- LLM / Ollama (Local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=uis_quan

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# --- Google Gemini ---
GOOGLE_API_KEY=your-google-api-key-here

# --- Groq ---
GROQ_API_KEY=gsk_your-groq-api-key-here

# --- Mistral AI ---
MISTRAL_API_KEY=your-mistral-api-key-here

# --- Together AI ---
TOGETHER_API_KEY=your-together-api-key-here

# --- OpenRouter ---
OPENROUTER_API_KEY=your-openrouter-api-key-here

# --- HuggingFace ---
HUGGINGFACE_TOKEN=hf_your-huggingface-token-here

# --- Database ---
DATABASE_URL=sqlite:///./data/ml_agents.db
REDIS_URL=redis://localhost:6379/0

# --- FastAPI Server ---
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Data Lake ---
DATA_LAKE_PATH=./data

# --- Finance Domain ---
CCXT_EXCHANGE=binance
CCXT_API_KEY=your-ccxt-api-key-here
CCXT_SECRET=your-ccxt-secret-here

# --- Education Domain ---
EDUCATION_DB_URL=sqlite:///./data/education.db

# --- Science Domain ---
PUBCHEM_API_URL=https://pubchem.ncbi.nlm.nih.gov/rest/pug

# --- Monitoring ---
PROMETHEUS_PORT=9090
GRAFANA_URL=http://localhost:3000

# --- Model Paths ---
MODEL_CACHE_DIR=./models
TRANSFORMERS_CACHE=./models/transformers
TORCH_HOME=./models/torch
